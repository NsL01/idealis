<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_collaborator_tree" model="ir.ui.view">
        <field name="name">account.move.collaborator.tree</field>
        <field name="model">account.move.collaborator</field>
        <field name="arch" type="xml">
            <list string="Collaborators" editable="bottom">
                <field name="contributor_id"/>
                <field name="amount"/>
                <field name="percentage" widget="percentage"/>
                <field name="amount_paid" readonly="1"/>
                <field name="amount_remaining" readonly="1"/>
                <field name="status" readonly="1"/>
                <button name="action_send_reminder" type="object" string="Send Reminder" icon="fa-envelope" invisible="status == 'paid'"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_account_move_collaborator_form" model="ir.ui.view">
        <field name="name">account.move.collaborator.form</field>
        <field name="model">account.move.collaborator</field>
        <field name="arch" type="xml">
            <form string="Collaborator">
                <sheet>
                    <group>
                        <group>
                            <field name="contributor_id"/>
                            <field name="status" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="percentage" widget="percentage"/>
                            <field name="amount_paid" readonly="1"/>
                            <field name="amount_remaining" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
